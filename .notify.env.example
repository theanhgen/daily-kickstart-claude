# Ntfy notification config
# Copy to .notify.env and fill in your values:
#   cp .notify.env.example .notify.env
#
# .notify.env is gitignored -- your credentials stay local.

# Required: your ntfy topic name
NOTIFY_NTFY_TOPIC="your-topic-name"

# Optional: access token for authenticated publishing
# Generate at https://ntfy.sh/account → Access tokens
NOTIFY_NTFY_TOKEN=""

# Optional: override ntfy host (default: https://ntfy.sh)
# NOTIFY_NTFY_HOST="https://ntfy.sh"
